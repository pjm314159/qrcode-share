# ============================================================
# QRcode Share - Environment Configuration
# ============================================================
# Copy this file to .env and customize values before deploying.
#   cp .env.example .env
#
# All variables have sensible defaults for Docker deployment.
# Only override what you need to change.
# ============================================================

# ----------------------
# Database
# ----------------------
DB_PASSWORD=yourPassword

# ----------------------
# Backend Server
# ----------------------
HOST=0.0.0.0
PORT=3000
RUST_LOG=info,qrcode_share_backend=debug
DATABASE_URL=postgres://qrcode:yourPassword@localhost:5432/qrcode_share

# Database pool (for local development only; Docker uses auto-generated URL)
DB_MAX_CONNECTIONS=5
DB_MIN_CONNECTIONS=1

# ----------------------
# Channel & Message Limits
# ----------------------
MAX_CHANNELS=5000
MAX_MESSAGES_PER_CHANNEL=300
MAX_MESSAGE_SIZE=5120
MESSAGE_TTL_SECONDS=3600
CHANNEL_TTL_DAYS=30

# ----------------------
# Connection Limits
# ----------------------
MAX_CONNECTIONS=500
MAX_CONNECTIONS_PER_CHANNEL=50

# ----------------------
# Rate Limiting
# ----------------------
MAX_MESSAGES_PER_MINUTE=60
MAX_CHANNELS_PER_USER=10

# ----------------------
# Performance Tuning
# ----------------------
CLEANUP_INTERVAL_SECONDS=120
HEARTBEAT_INTERVAL_SECONDS=30
CONNECTION_TIMEOUT_SECONDS=60
BROADCAST_BUFFER_SIZE=256

# ----------------------
# CORS
# ----------------------
# Comma-separated origins, or * for any
CORS_ORIGINS=*

# ----------------------
# Frontend
# ----------------------
FRONTEND_PORT=80

# ----------------------
# WeChat JS-SDK (Optional)
# ----------------------
# Required for QR scanning in WeChat browser.
# If not configured or verification fails, the app will
# fall back to the standard browser QR scanner automatically.
#
# Steps:
#   1. Register a WeChat Official Account at https://mp.weixin.qq.com
#   2. Add your server IP to the IP whitelist (Settings > Basic > IP Whitelist)
#   3. Configure JS-SDK safe domain (Settings > JS-SDK Safe Domain)
#   4. Fill in the values below
#
# WX_APPID=your_wechat_app_id
# WX_SECRET=your_wechat_app_secret
